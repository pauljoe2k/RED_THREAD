# ─── Backend API ─────────────────────────────────────────────────────────────
# Required. In production set this to your Render backend URL.
# Must start with NEXT_PUBLIC_ to be exposed to the browser bundle.
#
# Development:
NEXT_PUBLIC_API_URL=http://localhost:5000/api
#
# Production (set in Vercel Dashboard → Settings → Environment Variables):
# NEXT_PUBLIC_API_URL=https://redthread-api.onrender.com/api
