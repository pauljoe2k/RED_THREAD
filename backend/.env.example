# ─── Server ───────────────────────────────────────────────────────────────────
# Required: leave no defaults for production values
PORT=5000

# ─── Database ─────────────────────────────────────────────────────────────────
# Required: MongoDB Atlas connection string
# Format: mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority
MONGO_URI=mongodb+srv://<user>:<password>@cluster0.mongodb.net/redthread?retryWrites=true&w=majority

# ─── Auth ─────────────────────────────────────────────────────────────────────
# Required: generate a strong random secret for production
# Tip: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=change_me_to_a_long_random_string_in_production
JWT_EXPIRES_IN=7d

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Required in production: comma-separated list of allowed frontend origins
# Example: https://redthread.vercel.app,https://www.redthread.com
CLIENT_ORIGIN=http://localhost:3000

# ─── Runtime ──────────────────────────────────────────────────────────────────
# Set to "production" on Render — this controls error detail level and logging
NODE_ENV=development
